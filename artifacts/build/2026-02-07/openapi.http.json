{"openapi":"3.1.0","info":{"title":"Mitchopolis Evidence AI Engine","version":"1.0.0"},"paths":{"/api/evidence/process":{"post":{"tags":["Evidence"],"summary":"Process Evidence","description":"v1 stub implementation.\n\nLater this should:\n- call classifier.py to classify evidence\n- call ocr.py if items reference files\n- call timeline.py to build proper timeline entries\n\nFor now it:\n- validates input\n- logs basic info\n- returns a simple timeline built from the input items","operationId":"process_evidence_api_evidence_process_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ProcessEvidenceRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ProcessEvidenceResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/evidence/ingest":{"post":{"tags":["Evidence"],"summary":"Ingest Evidence","description":"Ingest evidence items, run OCR + classification + timeline building.\n\nFor v1, this simply forwards to the main process_evidence pipeline so we\ndon't duplicate logic. Later we can add extra ingestion-only behavior\n(e.g., storage, hashing, queueing).","operationId":"ingest_evidence_api_evidence_ingest_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ProcessEvidenceRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ProcessEvidenceResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/evidence/export":{"get":{"tags":["Evidence"],"summary":"Export all evidence as a ZIP file","description":"Build a ZIP archive from the evidence folder and return it for download.\n\nQuery params:\n- `folder`: optional absolute path to the folder to export. If omitted,\n  tries environment variable `EVIDENCE_SOURCE_FOLDER`, then falls back to\n  the default `~/Mitchopolis/parenting_evidence/text_logs`.","operationId":"export_evidence_api_evidence_export_get","parameters":[{"name":"folder","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Folder"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/health":{"get":{"summary":"Health","operationId":"health_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}}},"components":{"schemas":{"EvidenceItem":{"properties":{"id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Id","description":"Optional client-side id for the evidence item"},"source":{"type":"string","title":"Source","description":"Where this evidence came from (e.g. 'ofw', 'sms', 'photo')"},"content":{"type":"string","title":"Content","description":"Raw text or description associated with the evidence"},"media_path":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Media Path","description":"Absolute or relative path to the underlying file, if any"},"tags":{"items":{"type":"string"},"type":"array","title":"Tags","description":"Optional tags applied by the client"}},"type":"object","required":["source","content"],"title":"EvidenceItem"},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"ProcessEvidenceRequest":{"properties":{"case_id":{"type":"string","title":"Case Id","description":"Case identifier in your system"},"items":{"items":{"$ref":"#/components/schemas/EvidenceItem"},"type":"array","title":"Items","description":"List of evidence items to process"}},"type":"object","required":["case_id","items"],"title":"ProcessEvidenceRequest"},"ProcessEvidenceResponse":{"properties":{"case_id":{"type":"string","title":"Case Id"},"timeline":{"items":{"$ref":"#/components/schemas/TimelineEntry"},"type":"array","title":"Timeline"},"classified_count":{"type":"integer","title":"Classified Count"}},"type":"object","required":["case_id","timeline","classified_count"],"title":"ProcessEvidenceResponse"},"TimelineEntry":{"properties":{"id":{"type":"string","title":"Id"},"case_id":{"type":"string","title":"Case Id"},"summary":{"type":"string","title":"Summary"},"timestamp":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Timestamp"},"evidence_ids":{"items":{"type":"string"},"type":"array","title":"Evidence Ids"},"predicted_type":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Predicted Type"},"ocr_used":{"type":"boolean","title":"Ocr Used","default":false}},"type":"object","required":["id","case_id","summary"],"title":"TimelineEntry"},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}